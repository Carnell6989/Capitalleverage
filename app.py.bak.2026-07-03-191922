def _openalice_env():
    from dotenv import load_dotenv
    load_dotenv(dotenv_path=".env", override=True)
    return {
        "base": os.getenv("OPENALICE_BASE_URL", "http://127.0.0.1:47331").rstrip("/"),
        "token": os.getenv("OPENALICE_ADMIN_TOKEN", "").strip(),
    }

def _openalice_login_session():
    cfg = _openalice_env()
    base = cfg["base"]
    token = cfg["token"]

    if not token:
        return None, "Missing OPENALICE_ADMIN_TOKEN in .env"

    sess = requests.Session()
    r = sess.post(
        f"{base}/api/auth/login",
        json={"token": token},
        timeout=30,
    )

    if r.status_code != 200:
        return None, f"OpenAlice login failed: {r.status_code} {r.text}"

    return sess, None

def _openalice_get_or_create_trading_workspace():
    sess, err = _openalice_login_session()
    if err:
        return None, None, err

    cfg = _openalice_env()
    base = cfg["base"]

    # 1) list workspaces
    r = sess.get(f"{base}/api/workspaces", timeout=30)
    if r.status_code != 200:
        return None, None, f"OpenAlice workspace list failed: {r.status_code} {r.text}"

    data = r.json()
    items = []

    if isinstance(data, list):
        items = data
    elif isinstance(data, dict):
        # support either {"workspaces":[...]} or {"items":[...]}
        items = data.get("workspaces") or data.get("items") or data.get("data") or []

    target_names = {
        "Capital Leverage Trading",
        "capital-leverage-trading",
        "Trading Lab",
    }

    for ws in items:
        ws_name = str(ws.get("name", "")).strip()
        ws_id = ws.get("id")
        if ws_id and ws_name in target_names:
            return sess, ws_id, None

    # 2) create if missing
    payload = {
        "name": "Capital Leverage Trading",
        "template": "chat"
    }
    r = sess.post(f"{base}/api/workspaces", json=payload, timeout=30)

    if r.status_code not in (200, 201):
        return None, None, f"OpenAlice workspace create failed: {r.status_code} {r.text}"

    created = r.json()
    ws_id = created.get("id") or (created.get("workspace") or {}).get("id")
    if not ws_id:
        return None, None, f"OpenAlice workspace created but no id returned: {created}"

    return sess, ws_id, None

def _openalice_headless(prompt_text):
    sess, ws_id, err = _openalice_get_or_create_trading_workspace()
    if err:
        return {"success": False, "message": err}

    cfg = _openalice_env()
    base = cfg["base"]

    payload = {
        "prompt": prompt_text,
        "agent": "codex",
        "async": False,
        "timeoutMs": 180000
    }

    r = sess.post(
        f"{base}/api/workspaces/{ws_id}/headless",
        json=payload,
        timeout=240
    )

    if r.status_code != 200:
        return {
            "success": False,
            "message": f"OpenAlice headless failed: {r.status_code} {r.text}"
        }

    data = r.json()

    # try to normalize common result shapes
    text = (
        data.get("output")
        or data.get("result")
        or data.get("response")
        or data.get("text")
        or data.get("message")
    )

    if not text:
        text = str(data)

    return {
        "success": True,
        "workspace_id": ws_id,
        "answer": text
    }


