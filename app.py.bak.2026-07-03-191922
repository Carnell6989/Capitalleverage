def load_json(path):
    if not path.exists():
        return []
    return json.loads(path.read_text())

def save_json(path, data):
    path.write_text(json.dumps(data, indent=2))

def extract_text_from_file(path):
    suffix = path.suffix.lower()

    if suffix == ".pdf":
        text = ""
        with fitz.open(path) as pdf:
            for i, page in enumerate(pdf):
                text += f"\n\n--- Page {i+1} ---\n"
                text += page.get_text()
        return text.strip()

    if suffix == ".docx":
        document = docx.Document(path)
        return "\n".join([p.text for p in document.paragraphs]).strip()

    return path.read_text(errors="ignore").strip()


def _openalice_login_session():
    import os
    from dotenv import load_dotenv

    load_dotenv(dotenv_path=".env", override=True)

    base = os.getenv("OPENALICE_BASE_URL", "http://127.0.0.1:47331").rstrip("/")
    token = os.getenv("OPENALICE_ADMIN_TOKEN", "").strip()

    if not token:
        return None, "Missing OPENALICE_ADMIN_TOKEN in .env"

    sess = requests.Session()

    login_url = f"{base}/api/auth/login"
    payload = {"token": token}

    try:
        r = sess.post(login_url, json=payload, timeout=30)
    except Exception as e:
        return None, f"OpenAlice login request failed: {e}"

    if r.status_code != 200:
        return None, f"OpenAlice login failed: {r.status_code} {r.text}"

    return sess, None


def _openalice_chat(prompt_text):
    import os
    from dotenv import load_dotenv

    load_dotenv(dotenv_path=".env", override=True)

    base = os.getenv("OPENALICE_BASE_URL", "http://127.0.0.1:47331").rstrip("/")

    sess, err = _openalice_login_session()
    if err:
        return {"success": False, "message": err}

    payload = {
        "prompt": prompt_text
    }

    chat_routes = [
        f"{base}/api/workspaces/chat",
        f"{base}/api/chat",
        f"{base}/api/ask"
    ]

    last_error = None

    for url in chat_routes:
        try:
            r = sess.post(url, json=payload, timeout=120)
            if r.status_code == 200:
                try:
                    data = r.json()
                except Exception:
                    return {"success": True, "raw": r.text}

                if isinstance(data, dict):
                    # try common response keys
                    for key in ["response", "message", "answer", "text", "content"]:
                        if key in data and data[key]:
                            return {"success": True, "response": data[key], "raw_json": data}
                    return {"success": True, "raw_json": data}
                return {"success": True, "raw": str(data)}
            else:
                last_error = f"{url} -> {r.status_code}: {r.text}"
        except Exception as e:
            last_error = f"{url} -> {e}"

    return {"success": False, "message": f"OpenAlice request failed. {last_error}"}


