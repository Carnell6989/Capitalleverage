from flask import jsonify, request
from dotenv import load_dotenv

load_dotenv(dotenv_path=".env", override=True)

def openalice_base():
    return os.getenv("OPENALICE_BASE_URL", "http://127.0.0.1:47331").rstrip("/")

def openalice_token():
    return os.getenv("OPENALICE_ADMIN_TOKEN", "").strip()

def openalice_headers():
    token = openalice_token()
    headers = {"Content-Type": "application/json"}
    if token:
        headers["Authorization"] = f"Bearer {token}"
    return headers

def trading_lab_system_prompt(user_prompt: str, mode: str = "strategy"):
    max_stop = os.getenv("MAX_STOP_LOSS_PERCENT", "1")
    take_profit = os.getenv("DEFAULT_TAKE_PROFIT_PERCENT", "3")
    max_trades = os.getenv("DEFAULT_MAX_TRADES_PER_DAY", "3")
    gbpjpy = os.getenv("DEFAULT_FOREX_RESEARCH_PAIR", "GBPJPY")

    return f"""
You are Capital Leverage Trading Lab, integrated with OpenAlice.

Your job is to answer like a serious trading desk for PAPER TRADING ONLY.

Mandatory rules:
- Trading mode is PAPER ONLY unless explicitly changed later by the owner.
- Max stop loss per trade = {max_stop}%.
- Default take profit target = {take_profit}% unless better R:R is justified.
- Max trades per day default = {max_trades}.
- Do NOT make reckless promises.
- Give practical, structured trading answers.
- If the user asks for forex, treat {gbpjpy} as a research-mode pair unless a forex broker is connected later.
- Prefer concrete outputs: strongest names, watchlist, entry zones, stop levels, take profit levels, invalidation, and what to watch next.
- If asked for "best stocks", rank the strongest candidates and explain why.
- If asked about GBPJPY, give a research-mode setup with session bias, key levels, risk, and invalidation.
- Always format the response in this structure:

1. HERE IS THE MOVE
2. TOP NAMES / PAIRS TO WATCH
3. ENTRY PLAN
4. STOP LOSS PLAN
5. TAKE PROFIT PLAN
6. WHAT INVALIDATES THE TRADE
7. NEXT 3 ACTIONS

User request:
{user_prompt}
""".strip()

def call_openalice(prompt_text: str):
    """
    This is the first integration layer.
    For now we send the prompt through a generic OpenAlice-compatible request shape.
    If your OpenAlice instance uses a different endpoint later, we only swap it here.
    """
    base = openalice_base()
    headers = openalice_headers()

    payload = {
        "message": prompt_text,
        "mode": "chat"
    }

    # Try a few possible endpoints so we can work with the current OpenAlice build.
    candidate_paths = [
        "/api/chat",
        "/api/ask",
        "/api/messages",
        "/api/agent/chat",
        "/api/workspaces/chat"
    ]

    last_error = None

    for path in candidate_paths:
        url = base + path
        try:
            r = requests.post(url, json=payload, headers=headers, timeout=90)
            if r.status_code in (200, 201):
                try:
                    data = r.json()
                except Exception:
                    return {"success": True, "answer": r.text, "source": url}

                # Try common response shapes
                for key in ["answer", "response", "message", "content", "text"]:
                    if isinstance(data, dict) and data.get(key):
                        return {"success": True, "answer": data[key], "source": url}

                return {"success": True, "answer": str(data), "source": url}
            else:
                last_error = f"{url} -> {r.status_code}: {r.text[:500]}"
        except Exception as e:
            last_error = f"{url} -> {e}"

    return {"success": False, "message": f"OpenAlice request failed. {last_error}"}


